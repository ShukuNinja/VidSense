# Copy to `.env` (same folder as docker-compose.yml) and fill in.
# `docker compose` reads these automatically.

# Public domain for automatic HTTPS. Use `localhost` for local testing.
DOMAIN=localhost

# JWT signing secret. Generate: openssl rand -hex 32
# Changing this signs all users out.
VIDSENSE_SECRET=change-me-to-a-long-random-string

# Ollama model (must fit your GPU). llama3.2:3b is small + fast.
VIDSENSE_MODEL=llama3.2:3b
