# Copy to `.env` (same folder as docker-compose.yml) and fill in.
# `docker compose` reads these automatically.

# Public domain for automatic HTTPS. Use `localhost` for local testing.
DOMAIN=localhost

# JWT signing secret. Generate: openssl rand -hex 32
# Changing this signs all users out.
VIDSENSE_SECRET=change-me-to-a-long-random-string

# Ollama model (must fit your GPU). llama3.2:3b is small + fast.
VIDSENSE_MODEL=llama3.2:3b

# --- LLM provider ---
# "ollama" = local (needs the GPU ollama service). "openai" = any
# OpenAI-compatible hosted API, which lets you deploy with NO GPU.
LLM_PROVIDER=ollama
# When LLM_PROVIDER=openai, set these. Examples:
#   OpenAI:     LLM_API_BASE=https://api.openai.com/v1     LLM_MODEL=gpt-4o-mini
#   Groq:       LLM_API_BASE=https://api.groq.com/openai/v1 LLM_MODEL=llama-3.1-8b-instant
#   OpenRouter: LLM_API_BASE=https://openrouter.ai/api/v1  LLM_MODEL=anthropic/claude-3.5-haiku
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
